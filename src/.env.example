# Copy this file to .env and fill in your values
# cp .env.example .env

# SQL Server SA password (must meet complexity: min 8 chars, uppercase, lowercase, digit, special char)
SA_PASSWORD=YourStrongPassword123!

# JWT signing secret — generate a new value with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# ASPNETCORE environment (Production | Development)
ASPNETCORE_ENVIRONMENT=Production
